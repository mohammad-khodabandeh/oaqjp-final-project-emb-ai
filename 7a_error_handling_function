# -*- coding: ascii -*-
"""
emotion detection service
=========================

"""
import requests
import json

EMOTION_URL = \
    "https://sn-watson-emotion.labs.skills.network/v1/watson.runtime.nlp.v1/NlpService/EmotionPredict"
MODEL_ID = "emotion_aggregated-workflow_lang_en_stock"
DEFAULT = {
    "anger": None,
    "disgust": None,
    "fear": None,
    "joy": None,
    "sadness": None,
    "dominant_emotion": None
}

def emotion_detector(text_to_analyze):
    """
    detect emotions based on the input text sentiment

    Parameters:
      text_to_analyze(str):
        input text to analyse

    Return:
      dict: the formatted emotion map
    """
    header = {
        "grpc-metadata-mm-model-id": MODEL_ID
    }
    payload = {
        "raw_document": {
            "text": text_to_analyze
        }
    }

    response = requests.post(
        EMOTION_URL,
        json = payload,
        headers = header
    )

    if response.status_code == 400:
        return DEFAULT


    predictions = json.loads(response.text).get("emotionPredictions", [])
    if not predictions:
        return DEFAULT

    emotions =  next((item["emotion"] for item in predictions), None)
    if not emotions:
        return DEFAULT

    emotions["dominant_emotion"] = max(emotions, key=emotions.get)
    return dict(emotions)
